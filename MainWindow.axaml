<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="MojeLogowanieGUI.MainWindow"
        Title="MojeLogowanieGUI">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15">
    
    <TextBlock Text="Logowanie do systemu Collab " HorizontalAlignment="Center" />
    
    <TextBox Name="LoginBox" PlaceholderText="Wpisz login" Width="200" />
    
    <TextBox Name="PasswordBox" PlaceholderText="Wpisz hasło" PasswordChar="*" Width="200" />
    
    <Button Name="LoginButton" Content="Zaloguj" Width="200" HorizontalContentAlignment="Center" Click = "ZalogujPrzycisk_Click" />
    
    <TextBlock Name="MessageBlock" Text="" Foreground="Red" HorizontalAlignment="Center" />

    <Button Name="Register_button" Content="Zarejestruj się" Width="200" HorizontalContentAlignment="Center" Click = "ZarejestrujPrzycisk_Click" />


</StackPanel>
</Window>
